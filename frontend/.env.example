# =============================================================
# FRONTEND — Variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA commitees el .env.local con valores reales al repositorio.
# =============================================================

# -------------------------------------------------------------
# API
# URL pública del backend en Render (sin slash al final)
# -------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="https://TU-BACKEND.onrender.com"

# -------------------------------------------------------------
# URLS DEL SITIO
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://TU-PROYECTO.vercel.app"

# -------------------------------------------------------------
# CLOUDINARY (subida de imágenes en admin)
# Obtén estos valores en: https://cloudinary.com/console
#   - Cloud name: panel principal, esquina superior izquierda
#   - Upload preset: Settings → Upload → Upload presets (debe ser "Unsigned")
# -------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="jerseys_raw_products"
