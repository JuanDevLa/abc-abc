# =============================================================
# BACKEND — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el .env con valores reales al repositorio.
# =============================================================

# -------------------------------------------------------------
# BASE DE DATOS (Neon PostgreSQL)
# Obtén esta URL en: https://console.neon.tech → tu proyecto → Connection string
# Asegúrate de agregar ?sslmode=require al final
# -------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# -------------------------------------------------------------
# AUTENTICACIÓN
# JWT_SECRET: cadena aleatoria de mínimo 64 caracteres
#   Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ADMIN_PASSWORD_HASH: hash bcrypt de la contraseña de admin
#   Genera uno con: node -e "require('bcrypt').hash('TU_PASSWORD',12).then(h=>console.log(h))"
# -------------------------------------------------------------
JWT_SECRET="reemplaza_con_cadena_aleatoria_de_64_caracteres_minimo"
ADMIN_PASSWORD_HASH="$2b$12$reemplaza_con_hash_bcrypt_real"

# -------------------------------------------------------------
# STRIPE (Pagos)
# Obtén estas claves en: https://dashboard.stripe.com/apikeys
#   - Usa claves "sk_test_..." para desarrollo
#   - Usa claves "sk_live_..." para producción
# STRIPE_WEBHOOK_SECRET: se obtiene al registrar el webhook en Stripe Dashboard
#   URL del webhook: https://TU-BACKEND.onrender.com/api/webhooks/stripe
# -------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -------------------------------------------------------------
# URLs
# FRONTEND_URL: URL pública del frontend (Vercel)
# CORS_ORIGIN: si necesitas permitir dominios extra, sepáralos por coma
#   (JerseysRaw.com y www.JerseysRaw.com ya están permitidos por defecto)
# -------------------------------------------------------------
FRONTEND_URL="https://TU-PROYECTO.vercel.app"
CORS_ORIGIN=""

# -------------------------------------------------------------
# EMAIL (Brevo SMTP — https://app.brevo.com)
# 1. Crea cuenta gratuita en Brevo
# 2. Ve a: Configuración → SMTP & API → SMTP
# 3. Copia host, puerto, usuario y contraseña SMTP
# Límite free: 300 emails/día
# -------------------------------------------------------------
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="tu-email@ejemplo.com"
SMTP_PASS="tu-clave-smtp-de-brevo"
SMTP_FROM="Jerseys Raw <no-reply@jerseys-raw.com>"

# -------------------------------------------------------------
# 17TRACK (Rastreo de paquetes)
# Crea cuenta en: https://www.17track.net/en/service/api
# Obtén tu API key en: Dashboard → API Key
# Plan gratuito: 100 rastreos/mes
# -------------------------------------------------------------
TRACK17_API_KEY="tu_api_key_de_17track"

# -------------------------------------------------------------
# SERVIDOR
# NODE_ENV: "development" o "production"
# PORT: Render lo asigna automáticamente — no hace falta cambiarlo
# -------------------------------------------------------------
NODE_ENV="production"
PORT="4000"
