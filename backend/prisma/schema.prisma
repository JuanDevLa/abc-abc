// ---------- GENERATOR + DATASOURCE ----------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------
enum Audience {
  HOMBRE
  MUJER
  NINO
  UNISEX // Agregado para compatibilidad
}

enum Sleeve {
  SHORT
  LONG
}

enum JerseyStyle {
  HOME
  AWAY
  THIRD
  GK
  SPECIAL
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ShippingMethod enum removed — field is now a free-form String
// so that descriptive labels (e.g. "Estándar Internacional (22-25 días)") are stored directly.

enum FulfillmentType {
  LOCAL
  DROPSHIPPING
}

// ---------- CATÁLOGO GENERAL ----------

// 1. NUEVO: Agregamos Categoría para que funcione tu formulario actual
model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 2. NUEVO: Agregamos Tags (estaba abajo, lo subí por orden)
model Tag {
  id    String       @id @default(uuid())
  name  String       @unique
  slug  String       @unique
  items ProductTag[]
}

// ---------- CATÁLOGO FUTBOL ----------
model League {
  id        String   @id @default(uuid())
  name      String
  country   String?
  slug      String   @unique
  clubs     Club[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  leagueId  String
  league    League    @relation(fields: [leagueId], references: [id])
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([leagueId])
}

model Season {
  id        String    @id @default(uuid())
  code      String    @unique // p.ej. "24/25"
  startYear Int
  endYear   Int
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String       @default("")
  brand       String?      // NUEVO: Agregado para tu formulario

  // Recompensas
  earnPoints   Boolean      @default(true)   // ¿Acumula puntos al comprar?
  redeemMaxQty Int?                          // null=ilimitado, 0=no canjeable, 1+=máx qty con puntos
  
  // Datos de Fútbol (Opcionales por ahora para no romper el formulario simple)
  jerseyStyle JerseyStyle? 
  authentic   Boolean      @default(false)
  
  clubId      String?      // Opcional
  club        Club?        @relation(fields: [clubId], references: [id])
  
  seasonId    String?      // Opcional
  season      Season?      @relation(fields: [seasonId], references: [id])

  // Datos Generales
  categoryId  String?      // NUEVO: Para clasificar (Camisetas, Retro, etc)
  category    Category?    @relation(fields: [categoryId], references: [id])

  images      ProductImage[]
  variants    ProductVariant[]
  tags        ProductTag[]
  reviews     Review[]
  orderItems  OrderItem[]

  // Logística — tipo de fulfillment del producto
  fulfillmentType FulfillmentType @default(LOCAL)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([clubId, seasonId, jerseyStyle, createdAt])
  @@index([slug])
  @@index([name])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) // Cascade para borrar fácil
  url       String
  width     Int?
  height    Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

// Variante = combinaciones vendibles
model ProductVariant {
  id                  String   @id @default(uuid())
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                 String   @unique
  barcode             String?  @unique
  
  // Características
  size                String?  // Opcional al inicio
  color               String?  // Opcional al inicio
  audience            Audience? // Opcional al inicio
  sleeve              Sleeve?   // Opcional
  
  hasLeaguePatch      Boolean  @default(false)
  hasChampionsPatch   Boolean  @default(false)
  isPlayerVersion     Boolean  @default(false) // false = Fan, true = Player
  allowsNameNumber    Boolean  @default(false)
  customizationPrice  Int      @default(19900) // $199.00 MXN en centavos
  
  // Precios
  priceCents          Int
  compareAtPriceCents Int?
  costCents           Int      @default(0) // Default 0 para no obligar a poner costo
  currency            String   @default("MXN")
  
  stock               Int      @default(0)
  isDropshippable     Boolean  @default(true) // Si false, al llegar a stock 0 se marca como Agotado
  weightGrams         Int?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]

  @@index([productId])
  @@index([size, audience, sleeve])
  @@index([priceCents])
  @@index([stock])
}

model StockMovement {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            // siempre positivo — unidades añadidas
  notes     String         @default("")
  createdAt DateTime       @default(now())

  @@index([variantId])
  @@index([createdAt])
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

// ---------- ÓRDENES ----------
model Order {
  id              String         @id @default(uuid())
  orderNumber     String         @unique  // "JR-20260309-XXXX"
  status          OrderStatus    @default(PENDING_PAYMENT)

  // Cliente
  email           String
  firstName       String
  lastName        String
  phone           String

  // Dirección
  address         String
  city            String
  state           String
  zipCode         String
  country         String         @default("México")
  reference       String?        @db.VarChar(120)

  // Envío
  shippingMethod  String
  shippingCents   Int
  trackingNumber  String?        @db.VarChar(100)

  // Totales (recalculados por el backend, NUNCA del frontend)
  subtotalCents        Int
  totalCents           Int
  rewardDiscountCents  Int            @default(0)  // Descuento aplicado con puntos
  rewardPointsUsed     Int            @default(0)  // Puntos canjeados
  couponCode          String?
  couponDiscountCents Int            @default(0)
  currency             String         @default("MXN")

  // Expiración — órdenes no pagadas se cancelan y devuelven stock
  expiresAt       DateTime?

  // Relaciones
  items           OrderItem[]
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([email])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relación con el producto (opcional — si el producto se borra, el item sobrevive)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId       String?

  // Snapshot del producto al momento de la compra
  productName     String
  productSlug     String
  productImageUrl String?
  variantSize     String?
  variantColor    String?

  quantity        Int
  unitPriceCents  Int
  totalCents      Int

  isDropshippable Boolean  @default(false)

  // Personalización (nombre y número en la playera)
  isPersonalized  Boolean  @default(false)
  customName      String?
  customNumber    String?

  @@index([orderId])
  @@index([productId])
}

// ---------- PROVEEDORES Y COMPRAS ----------
model Supplier {
  id        String          @id @default(uuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  notes     String?
  orders    PurchaseOrder[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum POStatus {
  DRAFT
  ORDERED
  RECEIVED_PARTIAL
  RECEIVED_ALL
  CANCELLED
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     POStatus            @default(DRAFT)
  currency   String              @default("MXN")
  items      PurchaseOrderItem[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  unitCostCents   Int
  qtyOrdered      Int
  qtyReceived     Int            @default(0)
  notes           String?

  @@index([purchaseOrderId])
  @@index([variantId])
}

// ---------- USUARIOS Y AUTH ----------
model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String
  name               String?
  phone              String?
  role               UserRole            @default(CUSTOMER)
  emailVerifiedAt    DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  verificationTokens VerificationToken[]
  orders             Order[]
  rewardPoints        Int                  @default(0)
  rewardHistory       RewardTransaction[]
  rewardRedemptions   RewardRedemption[]
  customerTags        String[]             @default([])
  notes              CustomerNote[]

  @@index([role])
  @@index([createdAt])
}

model CustomerNote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model RewardTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "EARN" | "REDEEM"
  points      Int
  description String
  orderId     String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
}

model VerificationToken {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  type       VerificationType
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, type, code])
  @@index([expiresAt])
}

// ────────── CUPONES ──────────
model Coupon {
  id                String        @id @default(uuid())
  code              String        @unique
  description       String        @default("")
  discountPercent   Int           @default(0)
  discountCents     Int?          // descuento fijo en centavos (alternativo a discountPercent)
  minPurchaseCents  Int           @default(0)
  firstPurchaseOnly Boolean       @default(false)
  usageLimit        Int?
  usageCount        Int           @default(0)
  startsAt          DateTime?
  expiresAt         DateTime?
  active            Boolean       @default(true)
  usages            CouponUsage[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([code])
  @@index([active])
}

model CouponUsage {
  id            String   @id @default(uuid())
  couponId      String
  coupon        Coupon   @relation(fields: [couponId], references: [id])
  orderId       String   @unique
  userId        String?
  email         String
  discountCents Int
  createdAt     DateTime @default(now())

  @@index([couponId])
  @@index([email])
}

// ────────── RESEÑAS ──────────
model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  email     String   @default("")
  image     String?  // URL de foto del cliente
  rating    Int      // 1-5
  comment   String?  @default("")
  verified  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([productId, createdAt])
}

// ────────── RECOMPENSAS CONFIG ──────────
model RewardConfig {
  id              Int      @id @default(1) // singleton
  enabled         Boolean  @default(true)
  centsPerPoint   Int      @default(275)   // centavos gastados = 1 punto (275 = ~$2.75 MXN)
  pointValueCents Int      @default(100)   // centavos de descuento por punto (100 = $1 MXN)
  goalPoints      Int      @default(1200)  // puntos para obtener jersey gratis
  updatedAt       DateTime @updatedAt
}

// ────────── CANJES DE RECOMPENSA ──────────
model RewardRedemption {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  couponCode String   @unique
  pointsUsed Int
  status     String   @default("PENDING") // PENDING | USED | EXPIRED
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([userId])
  @@index([status])
}

// ────────── NEWSLETTER ──────────
model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ────────── ANALÍTICAS ──────────
model ProductView {
  id        String   @id @default(uuid())
  productId String
  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([productId])
}